# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^en/espece/([a-z0-9-]+)/?$ index.php?page=espece&slug=$1&langue=en [QSA,L]

# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^en/oiseau/([a-z0-9-]+)/?$ index.php?page=oiseau&slug=$1&langue=en [QSA,L]

# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^en/reservation/([a-z0-9-]+)/?$ index.php?page=reservation&slug=$1&langue=en [QSA,L]

# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^en/?$ index.php?page=accueil&langue=en [QSA,L]

# ------------------------------------------------------------
# Sitemap (préparé pour l'étape 08)
# ------------------------------------------------------------
RewriteRule ^sitemap\.xml$ plan-du-site.php [L]

# ------------------------------------------------------------
# Section admin
# ------------------------------------------------------------
RewriteRule ^admin/?$ admin/index.php [L]
RewriteRule ^admin/([a-z0-9-]+)/?$ admin/$1.php [L]
